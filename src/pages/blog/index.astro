---
import BaseLayout from '../../layouts/BaseLayout.astro';

const blogPosts = [
  {
    slug: 'how-to-find-best-creators',
    title: 'How to Find the Best OnlyFans Creators in Your Niche',
    description: 'Learn discovery strategies, verification tips, and how to avoid scams when finding quality OnlyFans creators.',
    date: 'March 3, 2026',
    readTime: '8 min read',
  },
  {
    slug: 'onlyfans-vs-alternatives',
    title: 'OnlyFans vs Fansly, Patreon & More: Platform Comparison 2026',
    description: 'Compare OnlyFans to top alternatives. Which platform offers better features, pricing, and content for subscribers?',
    date: 'March 3, 2026',
    readTime: '10 min read',
  },
];
---

<BaseLayout
  title="OnlyFans Guides & Tips - BestOnlyFans.info Blog"
  description="Guides for discovering quality OnlyFans creators, platform comparisons, and subscription tips. Learn how to get the most value from creator platforms."
>
  <div class="max-w-4xl mx-auto px-4 py-12">
    <h1 class="text-4xl font-bold mb-4">OnlyFans Guides & Tips</h1>
    <p class="text-xl text-gray-600 mb-12">
      Learn how to discover quality creators, compare platforms, and get the most value from your subscriptions.
    </p>

    <div class="space-y-8">
      {blogPosts.map(post => (
        <article class="border-b pb-8">
          <a href={`/blog/${post.slug}/`} class="group">
            <h2 class="text-2xl font-semibold mb-2 group-hover:text-blue-600 transition">
              {post.title}
            </h2>
          </a>
          <div class="text-sm text-gray-500 mb-3">
            {post.date} · {post.readTime}
          </div>
          <p class="text-gray-700 mb-4">
            {post.description}
          </p>
          <a href={`/blog/${post.slug}/`} class="text-blue-600 hover:underline">
            Read more →
          </a>
        </article>
      ))}
    </div>
  </div>
</BaseLayout>
