              <td class="border px-3 py-2 font-semibold">Patreon</td>
              <td class="border px-3 py-2">NSFW restricted</td>
              <td class="border px-3 py-2">5-12%</td>
              <td class="border px-3 py-2">Non-adult creators, artists, podcasts</td>
            </tr>
            <tr>
              <td class="border px-3 py-2 font-semibold">Ko-fi</td>
