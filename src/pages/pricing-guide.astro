---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allListings = await getCollection('listings');

// Calculate pricing stats
const prices = allListings.map(l => {
  const priceStr = l.data.pricing?.startingPrice || '';
  const match = priceStr.match(/\$(\d+\.?\d*)/);
  return match ? parseFloat(match[1]) : 0;
}).filter(p => p > 0);

const avgPrice = prices.reduce((a, b) => a + b, 0) / prices.length;
const minPrice = Math.min(...prices);
const maxPrice = Math.max(...prices);

// Group by category
const byCategory = allListings.reduce((acc, listing) => {
  const cat = listing.data.category;
  if (!acc[cat]) acc[cat] = [];
  acc[cat].push(listing.data);
  return acc;
}, {} as Record<string, any[]>);

const categoryPricing = Object.entries(byCategory).map(([category, creators]) => {
  const catPrices = creators.map(c => {
    const priceStr = c.pricing?.startingPrice || '';
    const match = priceStr.match(/\$(\d+\.?\d*)/);
    return match ? parseFloat(match[1]) : 0;
  }).filter(p => p > 0);
  
  const avg = catPrices.reduce((a, b) => a + b, 0) / catPrices.length;
  const min = Math.min(...catPrices);
  const max = Math.max(...catPrices);
  
  return { category, avg, min, max, count: creators.length };
}).sort((a, b) => b.count - a.count);
---

<BaseLayout
  title="OnlyFans Pricing Guide 2026 - Subscription Costs & Value Analysis"
  description="Complete OnlyFans pricing guide for 2026. Compare subscription costs, understand hidden fees, and find the best value creators across all categories."
>
  <div class="max-w-4xl mx-auto">
    <h1 class="text-4xl font-bold mb-4">OnlyFans Pricing Guide 2026</h1>
    <p class="text-xl text-gray-600 mb-8">
      Everything you need to know about OnlyFans subscription costs, hidden fees, and getting the best value for your money.
    </p>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-12">
      <div class="bg-blue-50 border border-blue-200 rounded-lg p-6 text-center">
        <div class="text-3xl font-bold text-blue-600">${avgPrice.toFixed(2)}</div>
        <div class="text-sm text-gray-600 mt-1">Average Monthly Subscription</div>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-lg p-6 text-center">
        <div class="text-3xl font-bold text-green-600">${minPrice.toFixed(2)} - ${maxPrice.toFixed(2)}</div>
        <div class="text-sm text-gray-600 mt-1">Price Range</div>
      </div>
      <div class="bg-purple-50 border border-purple-200 rounded-lg p-6 text-center">
        <div class="text-3xl font-bold text-purple-600">{allListings.length}</div>
        <div class="text-sm text-gray-600 mt-1">Creators Analyzed</div>
      </div>
    </div>

    <!-- Pricing Overview -->
    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-6">💰 Subscription Pricing Breakdown</h2>
      
      <div class="bg-white border rounded-lg p-6 mb-6">
        <h3 class="text-xl font-bold mb-4">Budget Tiers</h3>
        <div class="space-y-4">
          <div class="flex items-start">
            <div class="bg-green-100 text-green-800 px-3 py-1 rounded font-semibold mr-4 min-w-[100px]">$4.99-7.99</div>
            <div>
              <strong>Budget-Friendly</strong>
              <p class="text-sm text-gray-600">Great for casual subscribers or trying new creators. Expect 3-5 posts per week.</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="bg-blue-100 text-blue-800 px-3 py-1 rounded font-semibold mr-4 min-w-[100px]">$8-14.99</div>
            <div>
              <strong>Standard</strong>
              <p class="text-sm text-gray-600">Most popular tier. Daily content, good engagement, solid value.</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="bg-purple-100 text-purple-800 px-3 py-1 rounded font-semibold mr-4 min-w-[100px]">$15-24.99</div>
            <div>
              <strong>Premium</strong>
              <p class="text-sm text-gray-600">High-quality production, extensive content libraries, excellent engagement.</p>
            </div>
          </div>
          <div class="flex items-start">
            <div class="bg-red-100 text-red-800 px-3 py-1 rounded font-semibold mr-4 min-w-[100px]">$25+</div>
            <div>
              <strong>Luxury</strong>
              <p class="text-sm text-gray-600">Celebrity creators, exclusive experiences, VIP treatment. Only for superfans.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing by Category -->
    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-6">📊 Average Pricing by Category</h2>
      <div class="space-y-3">
        {categoryPricing.map(({ category, avg, min, max, count }) => (
          <div class="bg-white border rounded-lg p-4 hover:shadow-md transition">
            <div class="flex justify-between items-center">
              <div>
                <h3 class="font-bold text-lg">{category}</h3>
                <p class="text-sm text-gray-600">{count} creators</p>
              </div>
              <div class="text-right">
                <div class="text-2xl font-bold text-blue-600">${avg.toFixed(2)}/mo</div>
                <div class="text-xs text-gray-500">Range: ${min.toFixed(2)} - ${max.toFixed(2)}</div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Hidden Costs -->
    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-6">⚠️ Hidden Costs to Watch Out For</h2>
      
      <div class="space-y-6">
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-4">
          <h3 class="font-bold text-lg mb-2">1. Pay-Per-View (PPV) Content</h3>
          <p class="text-gray-700 mb-2">Many creators send "exclusive" or "premium" content via DM that requires additional payment.</p>
          <ul class="list-disc list-inside text-sm text-gray-600 space-y-1">
            <li><strong>Typical Cost:</strong> $5-50 per piece of content</li>
            <li><strong>Frequency:</strong> Daily to weekly, depending on creator</li>
            <li><strong>Impact:</strong> Can double or triple your monthly costs</li>
          </ul>
          <p class="text-sm font-semibold text-yellow-800 mt-2">💡 Tip: Ask about PPV frequency before subscribing</p>
        </div>

        <div class="bg-orange-50 border-l-4 border-orange-400 p-4">
          <h3 class="font-bold text-lg mb-2">2. Tips & Gratuities</h3>
          <p class="text-gray-700 mb-2">While optional, some creators heavily encourage tipping for special attention or content unlocks.</p>
          <ul class="list-disc list-inside text-sm text-gray-600 space-y-1">
            <li><strong>Typical Cost:</strong> $5-100+ per tip</li>
            <li><strong>Social Pressure:</strong> Can feel obligatory in some communities</li>
            <li><strong>Impact:</strong> Moderate to high, depending on your boundaries</li>
          </ul>
          <p class="text-sm font-semibold text-orange-800 mt-2">💡 Tip: Tipping is always optional—don't feel pressured</p>
        </div>

        <div class="bg-red-50 border-l-4 border-red-400 p-4">
          <h3 class="font-bold text-lg mb-2">3. Custom Content Requests</h3>
          <p class="text-gray-700 mb-2">Personalized content created specifically for you at premium prices.</p>
          <ul class="list-disc list-inside text-sm text-gray-600 space-y-1">
            <li><strong>Typical Cost:</strong> $20-500+</li>
            <li><strong>Turnaround:</strong> Days to weeks</li>
            <li><strong>Impact:</strong> High if used regularly, zero if avoided</li>
          </ul>
          <p class="text-sm font-semibold text-red-800 mt-2">💡 Tip: Only request if you genuinely want personalized content</p>
        </div>
      </div>
    </section>

    <!-- Value Assessment -->
    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-6">💎 How to Assess Value</h2>
      
      <div class="bg-white border rounded-lg p-6">
        <h3 class="text-xl font-bold mb-4">Value Checklist</h3>
        <div class="space-y-3">
          <div class="flex items-start">
            <span class="text-green-600 mr-3">✅</span>
            <div>
              <strong>Content Frequency:</strong> At least 3-5 posts per week for standard subscriptions
            </div>
          </div>
          <div class="flex items-start">
            <span class="text-green-600 mr-3">✅</span>
            <div>
              <strong>Production Quality:</strong> HD photos/videos, good lighting, editing
            </div>
          </div>
          <div class="flex items-start">
            <span class="text-green-600 mr-3">✅</span>
            <div>
              <strong>Engagement:</strong> Creator responds to messages and comments
            </div>
          </div>
          <div class="flex items-start">
            <span class="text-green-600 mr-3">✅</span>
            <div>
              <strong>Transparency:</strong> Clear about PPV, tips, and additional costs upfront
            </div>
          </div>
          <div class="flex items-start">
            <span class="text-green-600 mr-3">✅</span>
            <div>
              <strong>Consistency:</strong> Regular upload schedule, no long gaps
            </div>
          </div>
          <div class="flex items-start">
            <span class="text-green-600 mr-3">✅</span>
            <div>
              <strong>Ratings:</strong> 4.5+ stars from verified subscribers
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Budget Strategies -->
    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-6">💰 Budget Strategies</h2>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-gradient-to-br from-green-50 to-green-100 border border-green-200 rounded-lg p-6">
          <h3 class="font-bold text-xl mb-2 text-green-800">$15-25/month</h3>
          <p class="text-sm text-gray-700 mb-3">Beginner Budget</p>
          <ul class="text-sm space-y-2">
            <li>• 2-3 lower-priced creators</li>
            <li>• Focus on one category</li>
            <li>• Avoid PPV content</li>
            <li>• Rotate monthly to explore</li>
          </ul>
        </div>

        <div class="bg-gradient-to-br from-blue-50 to-blue-100 border border-blue-200 rounded-lg p-6">
          <h3 class="font-bold text-xl mb-2 text-blue-800">$30-50/month</h3>
          <p class="text-sm text-gray-700 mb-3">Balanced Approach</p>
          <ul class="text-sm space-y-2">
            <li>• 3-5 creators, mixed pricing</li>
            <li>• 2-3 categories</li>
            <li>• Occasional PPV is okay</li>
            <li>• Mix favorites + new discoveries</li>
          </ul>
        </div>

        <div class="bg-gradient-to-br from-purple-50 to-purple-100 border border-purple-200 rounded-lg p-6">
          <h3 class="font-bold text-xl mb-2 text-purple-800">$50+/month</h3>
          <p class="text-sm text-gray-700 mb-3">Premium Experience</p>
          <ul class="text-sm space-y-2">
            <li>• 5-8 creators, all tiers</li>
            <li>• Multiple categories</li>
            <li>• PPV + tips budget</li>
            <li>• Custom content occasional</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- FAQs -->
    <section class="mb-12">
      <h2 class="text-3xl font-bold mb-6">❓ Pricing FAQs</h2>
      
      <div class="space-y-6">
        <div>
          <h3 class="font-bold text-lg mb-2">What's the average OnlyFans subscription cost?</h3>
          <p class="text-gray-700">The average subscription costs around ${avgPrice.toFixed(2)}/month, with most creators charging between $8-15/month for standard access.</p>
        </div>

        <div>
          <h3 class="font-bold text-lg mb-2">Are there any free OnlyFans accounts?</h3>
          <p class="text-gray-700">Some creators offer free subscriptions but rely heavily on PPV content for revenue. These often end up costing more than paid subscriptions.</p>
        </div>

        <div>
          <h3 class="font-bold text-lg mb-2">Can I cancel anytime?</h3>
          <p class="text-gray-700">Yes! OnlyFans subscriptions are month-to-month and can be cancelled at any time. You'll retain access until the end of your billing period.</p>
        </div>

        <div>
          <h3 class="font-bold text-lg mb-2">Do prices ever go on sale?</h3>
          <p class="text-gray-700">Yes, many creators offer promotional discounts (30-50% off) for first-time subscribers or during special events. Check creator profiles for current promotions.</p>
        </div>

        <div>
          <h3 class="font-bold text-lg mb-2">Which category offers the best value?</h3>
          <p class="text-gray-700">Fitness and educational creators often provide the best value, offering personalized coaching worth far more than the subscription cost. Adult content varies widely in value depending on the creator.</p>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <div class="bg-gradient-to-r from-blue-500 to-purple-600 text-white rounded-lg p-8 text-center">
      <h2 class="text-2xl font-bold mb-4">Find Value-Priced Creators</h2>
      <p class="mb-6">Browse our curated directory of top-rated creators with transparent pricing and verified reviews.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="bg-white text-blue-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-100 transition">
          Browse All Creators
        </a>
        <a href="/top-creators-2026" class="bg-blue-700 text-white px-6 py-3 rounded-lg font-semibold hover:bg-blue-800 transition">
          View Top Rated →
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
